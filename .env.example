# ==============================================
# ChatApp Microservice — Environment Variables
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=chatapp-microservice
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
DB_USER=chatapp
DB_PASSWORD=secret
DB_PORT=5432

# --- Service Ports (host mapping) ---
GATEWAY_PORT=8080
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=your-jwt-secret-change-in-production

# --- Redis ---
# Used internally by docker-compose, no need to change
# REDIS_URL=redis://redis:6379
